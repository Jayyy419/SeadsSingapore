# Copy this file to .env.local and fill in real values for local development.
# In production (Amplify), set these under App settings -> Environment variables instead.

# API Gateway endpoint that receives "Get Involved" interest-form submissions
# (name/email/interest) -> Lambda -> DynamoDB + SES notification email. If unset, the form
# still shows a message but the submission is discarded — see docs/ENVIRONMENT.md.
NEXT_PUBLIC_INTEREST_FORM_ENDPOINT=https://jztkgrm3lh.execute-api.ap-southeast-1.amazonaws.com/submit-interest

# Canonical production URL, used by src/app/sitemap.ts and src/app/robots.ts. Update this
# once a custom domain is live — falls back to the current Amplify URL otherwise.
NEXT_PUBLIC_SITE_URL=https://main.d2mrph1bcp6pjx.amplifyapp.com

# Cloudflare Turnstile site key (public — safe to expose in the browser bundle). Bot-check on
# the "Get Involved" form; if unset, the widget/script simply don't render and the Lambda skips
# verification (see backend/interest-form/README.md). The matching *secret* key lives in AWS
# Secrets Manager (seads/turnstile-secret-key), never here.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAD0posjeQ2nKduks

# Base URL of the same interest-form API Gateway, used to build the community-story
# submission and public approved-stories-feed endpoints (see /blog/submit and blog-content.tsx).
NEXT_PUBLIC_API_BASE_URL=https://jztkgrm3lh.execute-api.ap-southeast-1.amazonaws.com

# --- Admin panel (src/app/admin/**, src/middleware.ts) — server-only, never NEXT_PUBLIC_ ---
# ADMIN_PASSWORD: the shared password that gates /admin. Generate a long random value, not a
# memorable phrase — there's no per-user account here, so password strength is the only real
# defense against brute force (no rate limiting on /admin/login: infeasible to brute-force a
# ~120-bit random string regardless, see docs/LEARNING_GUIDE.md).
# ADMIN_SESSION_SECRET: random string used only to HMAC-sign the session cookie after login.
# Never needs to be memorable or known to admins — generate with `openssl rand -hex 32`.
# INTERNAL_API_KEY / INTERNAL_API_BASE_URL: shared secret + base URL the admin panel's own
# Route Handlers use to call the Lambda's /internal/* endpoints server-to-server. Must match
# the Lambda's own INTERNAL_API_KEY env var exactly.
# ADMIN_PASSWORD=
# ADMIN_SESSION_SECRET=
# INTERNAL_API_KEY=
# INTERNAL_API_BASE_URL=https://jztkgrm3lh.execute-api.ap-southeast-1.amazonaws.com

# Sentry error tracking — all optional, and all no-op (SDK simply doesn't initialize) if
# unset. NEXT_PUBLIC_SENTRY_DSN covers the browser; SENTRY_DSN covers the server/edge runtime
# (they're usually the same DSN value, just exposed differently since one is public-bundle-safe
# and the "server" one doesn't strictly need the NEXT_PUBLIC_ prefix). SENTRY_ORG/SENTRY_PROJECT
# are only used for source-map upload at build time, not runtime — leave unset if you don't
# want build-time source-map upload configured yet.
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
