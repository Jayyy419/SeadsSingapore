# Copy this file to .env.local and fill in real values for local development.
# In production (Vercel), set these under Project Settings -> Environment Variables instead.

# Public Google Apps Script Web App URL that receives "Get Involved" interest-form
# submissions (name/email/interest). If unset, the form still shows a success message
# but the submission is discarded — see docs/ENVIRONMENT.md.
NEXT_PUBLIC_GOOGLE_SHEETS_ENDPOINT=

# Canonical production URL, used by src/app/sitemap.ts and src/app/robots.ts. Update this
# once a custom domain is live — falls back to the current *.vercel.app URL otherwise.
NEXT_PUBLIC_SITE_URL=https://seadssg.vercel.app
